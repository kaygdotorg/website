---
/**
 * =============================================================================
 * LEGACY NOTES INDEX REDIRECT (/notes)
 * =============================================================================
 *
 * The standalone Notes section was merged into Blog. Keep the old /notes
 * landing page alive as a static HTML redirect so existing bookmarks and
 * search-engine results still land on the new writing index after the content
 * move.
 *
 * This page is intentionally framework-free: a canonical link, meta refresh,
 * and location.replace() are enough for output:static and keep the redirect
 * working even when the generated dist/ directory is served directly.
 */
const destination = "/blog";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting to /blog</title>
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={destination} />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
  </head>
  <body>
    <p>Redirecting to <a href={destination}>{destination}</a>.</p>
    <script is:inline>
      window.location.replace("/blog");
    </script>
  </body>
</html>
